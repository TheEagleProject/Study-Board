# Server
NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# PostgreSQL
DATABASE_URL=postgresql://studyboard:changeme@localhost:5432/studyboard
DB_POOL_MAX=10
DB_SSL=false

# Redis (session presence, rate-limit store, socket adapter)
REDIS_URL=redis://localhost:6379

# Auth
# Generate strong secrets with: openssl rand -hex 64
JWT_ACCESS_SECRET=replace_me_with_a_long_random_secret
JWT_REFRESH_SECRET=replace_me_with_a_different_long_random_secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# Logging
LOG_LEVEL=info
